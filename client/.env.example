# ============================================
# ALUMNI CHAT SYSTEM - FRONTEND CONFIGURATION
# ============================================
#
# Copy this file to .env.local and fill in your values
# .env.local is NOT committed to version control
#
# Quick Start:
# 1. cp .env.example .env.local
# 2. Update API_URL and DEBUG settings
# 3. npm start

# ============================================
# BACKEND API CONFIGURATION
# ============================================

# Backend API base URL (server root, WITHOUT /api suffix)
# Development: http://localhost:5000
# Production: https://api.yourdomain.com
REACT_APP_API_URL=http://localhost:5000

# API request timeout in milliseconds
# Default: 10000ms (10 seconds)
REACT_APP_API_TIMEOUT=10000

# ============================================
# DEBUGGING & DEVELOPMENT
# ============================================

# Enable API logging (logs all requests/responses)
# Set to "true" in development, "false" in production
REACT_APP_DEBUG=false

# ============================================
# OPTIONAL: MONITORING & ANALYTICS
# ============================================

# Future: Error tracking service (Sentry, Rollbar)
# REACT_APP_SENTRY_DSN=

# Future: Analytics service (Google Analytics, Mixpanel)
# REACT_APP_GA_ID=

# ============================================
# DEPLOYMENT ENVIRONMENTS
# ============================================

# Development (.env.local):
# REACT_APP_API_URL=http://localhost:5000
# REACT_APP_DEBUG=true

# Production (.env.production):
# REACT_APP_API_URL=https://api.yourdomain.com
# REACT_APP_API_TIMEOUT=15000
# REACT_APP_DEBUG=false

# ============================================
# BUILD INFORMATION
# ============================================

# These are set automatically by build tools:
# REACT_APP_VERSION (from package.json)
# REACT_APP_BUILD_TIME (current timestamp)
# NODE_ENV (development, production, test)
