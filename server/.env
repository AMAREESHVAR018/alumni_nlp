# ============================================
# ALUMNI CHAT SYSTEM - ENVIRONMENT CONFIGURATION
# ============================================
#
# Copy this file to .env and fill in your values
# NEVER commit .env file to version control
#
# Quick Start:
# 1. cp .env.example .env
# 2. Update values below
# 3. npm start

# ============================================
# SERVER CONFIGURATION
# ============================================

# Port the backend server listens on
PORT=5000

# Node environment (development, staging, production)
NODE_ENV=development

# ============================================
# DATABASE CONFIGURATION
# ============================================

# MongoDB connection string
# Local: mongodb://localhost:27017/alumni-chat
# MongoDB Atlas: mongodb+srv://user:password@cluster.mongodb.net/alumni-chat?retryWrites=true&w=majority
MONGO_URI=mongodb+srv://admin:admin123@cluster0.qughrez.mongodb.net/alumni-chat?retryWrites=true&w=majority&appName=Cluster0&maxPoolSize=10
# ============================================
# SECURITY - AUTHENTICATION
# ============================================

# JWT secret key (used to sign tokens)
# ⚠️ PRODUCTION: Use a strong random string (32+ characters)
# Generate: openssl rand -base64 32
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# JWT expiration time (in hours)
JWT_EXPIRY=24

# ============================================
# NLP SERVICE CONFIGURATION
# ============================================

# NLP service URL (Python Flask API)
# Local: http://localhost:5001
# Docker: http://nlp-service:5001
# Production: https://nlp-service.yourdomain.com
NLP_SERVICE_URL=http://localhost:5001

# Question similarity threshold (0.0 - 1.0)
# Higher = stricter matching, fewer false positives
# 0.80 = 80% similarity required to consider a match
SIMILARITY_THRESHOLD=0.80

# NLP service timeout in milliseconds
NLP_SERVICE_TIMEOUT=10000

# NLP retry attempts (if service is down)
NLP_SERVICE_RETRIES=2

# ============================================
# CORS CONFIGURATION
# ============================================

# Allowed frontend origin
# Development: http://localhost:3000
# Production: https://yourdomain.com
CORS_ORIGIN=http://localhost:3000

# ============================================
# LOGGING & MONITORING
# ============================================

# Log level (error, warn, info, debug)
LOG_LEVEL=info

# Future: Enable monitoring (Winston logger, DataDog, Sentry)
# DATADOG_API_KEY=
# SENTRY_DSN=

# ============================================
# OPTIONAL: FUTURE FEATURES
# ============================================

# Redis cache URL (for caching, sessions)
# Future: Enable caching for frequently searched questions
# REDIS_URL=redis://localhost:6379

# Message queue URL (for background jobs)
# Future: Process NLP embeddings asynchronously
# RABBITMQ_URL=amqp://localhost

# Email configuration (for notifications)
# Future: Send email notifications to users
# SMTP_HOST=
# SMTP_PORT=
# SMTP_USER=
# SMTP_PASS=

# ============================================
# PRODUCTION-SPECIFIC (Uncomment when deploying)
# ============================================

# Ensure all sensitive values come from environment
# Never hardcode secrets in code
# Use AWS Secrets Manager, HashiCorp Vault, or similar

# Example production values:
# NODE_ENV=production
# PORT=3000
# MONGO_URI=mongodb+srv://prod-user:strong-pass@prod-cluster.mongodb.net/alumni-chat
# JWT_SECRET=<generated-random-secret-from-vault>
# CORS_ORIGIN=https://yourdomain.com
# LOG_LEVEL=warn
